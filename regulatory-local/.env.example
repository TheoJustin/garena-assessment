AI_PROVIDER=openrouter

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free
OPENROUTER_EMBEDDING_MODEL=baai/bge-m3
OPENROUTER_APP_TITLE=THChat Regulatory Local
OPENROUTER_HTTP_REFERER=

# For Ollama on the same Docker host, `host.docker.internal` now works through
# Docker Compose on both macOS and modern Linux Docker engines.
# For a separate VPS, replace this with your reachable host or domain.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=ollama
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=embeddinggemma

BACKEND_URL=http://localhost:8001
NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

CHROMA_COLLECTION=ojk-regulatory-documents
AUTO_INGEST_BUNDLED_PDFS=false
ANONYMIZED_TELEMETRY=FALSE
CHROMA_PRODUCT_TELEMETRY_IMPL=telemetry.NoOpProductTelemetry
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
SIMILARITY_TOP_K=6
