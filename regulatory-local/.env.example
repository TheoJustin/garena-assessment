AI_PROVIDER=ollama

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free
OPENROUTER_APP_TITLE=THChat Regulatory Pinecone
OPENROUTER_HTTP_REFERER=

# For Ollama on the same Docker host, `host.docker.internal` now works through
# Docker Compose on both macOS and modern Linux Docker engines.
# For a separate VPS, replace this with your reachable host or domain.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=ollama
OLLAMA_CHAT_MODEL=qwen2.5:1.5b-instruct

# Pinecone integrated embeddings handle chunk indexing and text search.
# The field map on the demo index is `text -> text`.
PINECONE_API_KEY=
PINECONE_INDEX=chatbot-komunal
PINECONE_HOST=chatbot-komunal-rlrsd9x.svc.aped-4627-b74a.pinecone.io
PINECONE_NAMESPACE=regulatory-local
PINECONE_TEXT_FIELD=text
PINECONE_EMBED_MODEL=llama-text-embed-v2

# If you open the frontend from another machine, this must be the public
# backend URL of the VPS, not localhost.
BACKEND_URL=http://localhost:8001
NEXT_PUBLIC_BACKEND_URL=http://YOUR_SERVER_IP:8001
NEXT_PUBLIC_BACKEND_FETCH_TIMEOUT_MS=120000
NEXT_PUBLIC_INDEX_UPLOAD_TIMEOUT_MS=900000
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://YOUR_SERVER_IP:3001

AUTO_INGEST_BUNDLED_PDFS=false
CHUNK_SIZE=1800
CHUNK_OVERLAP=100
SIMILARITY_TOP_K=6
MAX_CONTEXT_CHARS_PER_HIT=900
